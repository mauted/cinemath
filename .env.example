# Required: Anthropic API key (teaching / OCR only — not animation).
ANTHROPIC_API_KEY=

# Optional model overrides (classify/extract vs freeform teach)
# ANTHROPIC_CLASSIFY_MODEL=claude-haiku-4-5
# ANTHROPIC_TEACH_MODEL=claude-sonnet-5
# ANTHROPIC_MODEL=claude-sonnet-5   # fallback when the above are unset
# CINEMATH_LOG_LEVEL=INFO           # DEBUG|INFO|WARNING|ERROR
# CINEMATH_LOG_COLOR=1              # 0 to disable ANSI colors
# CINEMATH_LOG_LINKS=1              # OSC-8 clickable paths (TTY default)
# CINEMATH_OUTPUT_DIR=outputs
